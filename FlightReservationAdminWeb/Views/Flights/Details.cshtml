@model FlightReservationAdminWeb.Soap.Flight
@{
    ViewData["Title"] = $"Lot {Model.FlightNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-airplane me-2"></i>Lot @Model.FlightNumber</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Powrót do listy
    </a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm">
            @if (Model.HasPhoto)
            {
                <img src="@Url.Action("Photo", new { id = Model.Id })" class="card-img-top" style="max-height: 300px; object-fit: cover;" alt="zdjęcie lotu" />
            }
            else
            {
                <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-muted" style="height: 300px;">
                    <div class="text-center">
                        <i class="bi bi-image" style="font-size: 4rem;"></i>
                        <div>Brak zdjęcia</div>
                    </div>
                </div>
            }
            <div class="card-body">
                <h4 class="card-title">@Model.CityFrom <i class="bi bi-arrow-right"></i> @Model.CityTo</h4>
                <p class="card-text text-muted">
                    <i class="bi bi-calendar me-1"></i>@Model.DepartureDate.ToString("dd.MM.yyyy")
                    &nbsp;&middot;&nbsp;
                    <i class="bi bi-clock me-1"></i>@Model.DepartureTime
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-white"><strong>Szczegóły</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Numer lotu</dt>
                    <dd class="col-sm-8">@Model.FlightNumber</dd>

                    <dt class="col-sm-4">Miasto wylotu</dt>
                    <dd class="col-sm-8">@Model.CityFrom</dd>

                    <dt class="col-sm-4">Miasto przylotu</dt>
                    <dd class="col-sm-8">@Model.CityTo</dd>

                    <dt class="col-sm-4">Data</dt>
                    <dd class="col-sm-8">@Model.DepartureDate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-4">Godzina</dt>
                    <dd class="col-sm-8">@Model.DepartureTime</dd>

                    <dt class="col-sm-4">Cena</dt>
                    <dd class="col-sm-8"><strong>@Model.Price.ToString("F2") PLN</strong></dd>

                    <dt class="col-sm-4">Wolne miejsca</dt>
                    <dd class="col-sm-8">@Model.AvailableSeats</dd>

                    <dt class="col-sm-4">Zdjęcie</dt>
                    <dd class="col-sm-8">@(Model.HasPhoto ? "Tak" : "Brak")</dd>
                </dl>
            </div>
            <div class="card-footer bg-white">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil me-1"></i>Edytuj
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Usuń
                </a>
            </div>
        </div>
    </div>
</div>
