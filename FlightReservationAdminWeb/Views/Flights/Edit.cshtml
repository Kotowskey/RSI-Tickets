@model FlightReservationAdminWeb.Models.FlightFormModel
@{
    ViewData["Title"] = $"Edycja lotu {Model.FlightNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-pencil me-2"></i>Edycja lotu @Model.FlightNumber</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Anuluj
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data" method="post" novalidate>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="HasExistingPhoto" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="FlightNumber" class="form-label"></label>
                    <input asp-for="FlightNumber" class="form-control" />
                    <span asp-validation-for="FlightNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CityFrom" class="form-label"></label>
                    <input asp-for="CityFrom" class="form-control" />
                    <span asp-validation-for="CityFrom" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CityTo" class="form-label"></label>
                    <input asp-for="CityTo" class="form-control" />
                    <span asp-validation-for="CityTo" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DepartureDate" class="form-label"></label>
                    <input asp-for="DepartureDate" class="form-control" type="date" />
                    <span asp-validation-for="DepartureDate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DepartureTime" class="form-label"></label>
                    <input asp-for="DepartureTime" class="form-control" placeholder="HH:MM" />
                    <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="AvailableSeats" class="form-label"></label>
                    <input asp-for="AvailableSeats" class="form-control" type="number" />
                    <span asp-validation-for="AvailableSeats" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label">Obecne zdjęcie</label>
                    <div>
                        @if (Model.HasExistingPhoto)
                        {
                            <img src="@Url.Action("Photo", new { id = Model.Id })" alt="zdjęcie" style="max-height: 160px; border-radius: 6px; border: 1px solid #dee2e6;" />
                        }
                        else
                        {
                            <span class="text-muted">Brak zdjęcia.</span>
                        }
                    </div>
                </div>

                <div class="col-md-8">
                    <label asp-for="Photo" class="form-label">Nowe zdjęcie (zastąpi obecne)</label>
                    <input asp-for="Photo" class="form-control" type="file" accept="image/*" />
                </div>
                @if (Model.HasExistingPhoto)
                {
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="RemovePhoto" class="form-check-input" type="checkbox" />
                            <label asp-for="RemovePhoto" class="form-check-label"></label>
                        </div>
                    </div>
                }
            </div>

            <hr class="my-4" />

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Zapisz zmiany
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Anuluj</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
